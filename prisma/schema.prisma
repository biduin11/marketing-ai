generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ArtifactType {
  COMPANY_ANALYSIS
  SWOT
  POSITIONING
  GROWTH_POINTS
  STRATEGY_30
  STRATEGY_90
  STRATEGY_180
  STRATEGY_365
  AUDIENCE_SEGMENTS
  BUYER_PERSONA
  JTBD
  COMPETITOR_ANALYSIS
  OFFER
  CJM
  CONTENT_PLAN
  REPORT_WEEKLY
  REPORT_MONTHLY
  REPORT_QUARTERLY
  DIRECTOR_DAILY
}

enum Plan {
  FREE
  PRO
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  projects             Project[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Project {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  niche         String?
  website       String?
  socials       Json           @default("{}")
  regions       String[]       @default([])
  products      String[]       @default([])
  competitors   String[]       @default([])
  budget        Int?
  goals         String?
  status        ProjectStatus  @default(DRAFT)

  // Extended company profile (Iteration 7)
  industry            String?
  dealCycle           String?
  brandTone           String?
  brandWords          String?
  clientType          String?
  audienceSegments    String?
  clientValues        String?
  objections          String?
  clientLanguage      String?
  currentChannels     String?
  marketingGoal       String?
  socialLinks         String?
  proofFacts          String?
  margin              Int?
  conversionRate      Int?
  currentCpl          Int?
  leadsPerMonth       Int?
  salesPerMonth       Int?
  avgCheck            Int?
  competitorsDetailed Json?
  artifacts     AiArtifact[]
  strategyTasks StrategyTask[]
  metrics       Metric[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

model Metric {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  channel     String
  date        DateTime @db.Date
  spend       Float    @default(0)
  revenue     Float    @default(0)
  leads       Int      @default(0)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, channel, date])
  @@index([projectId])
}

model AiArtifact {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      ArtifactType
  version   Int          @default(1)
  payload   Json
  model     String
  inputHash String
  createdAt DateTime     @default(now())

  tasks StrategyTask[]

  @@index([projectId, type])
}

model StrategyTask {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifactId String
  artifact   AiArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  taskKey    String
  done       Boolean    @default(false)
  updatedAt  DateTime   @updatedAt

  @@unique([artifactId, taskKey])
  @@index([projectId])
}
